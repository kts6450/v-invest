    },
    "PPO 추천 결과 필드 추출": {
      "main": [[{ "node": "3단계: RAG AI 시장 분석", "type": "main", "index": 0 }]]
    },
    "3단계: RAG AI 시장 분석": {
      "main": [[{ "node": "RAG 분석 결과 필드 추출", "type": "main", "index": 0 }]]
    },
    "RAG 분석 결과 필드 추출": {
      "main": [[{ "node": "4단계: AI 리포트 통합 생성", "type": "main", "index": 0 }]]
    },
    "4단계: AI 리포트 통합 생성": {
      "main": [[{ "node": "5단계: 프론트엔드로 리포트 전송 (SSE)", "type": "main", "index": 0 }]]
    }
  },

